# ── CarePilot CN — Streamlit Secrets Example ──────────────
# Copy this file to secrets.toml and fill in real values.
#
# On Streamlit Community Cloud, paste these into the Secrets
# panel in your app's dashboard settings.

[llm]
# Supported providers: "openai", "google"
provider = "openai"

# OpenAI-compatible settings
api_key = "sk-your-api-key-here"
base_url = "https://api.openai.com"
model = "gpt-4o-mini"

# Google Gemini settings (alternative)
# provider = "google"
# api_key = "your-google-api-key"
# model = "gemini-1.5-flash"

[app]
# Set to false to require real LLM calls (no rule-based fallback)
enable_fake_llm = true
default_window_days = 14
